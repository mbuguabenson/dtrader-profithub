{
    "version": 2,
    "buildCommand": "npm run build:all",
    "outputDirectory": "packages/core/dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "routes": [
        {
            "src": "^/js/(.*)$",
            "dest": "/js/$1"
        },
        {
            "src": "^/css/(.*)$",
            "dest": "/css/$1"
        },
        {
            "src": "^/assets/(.*)$",
            "dest": "/assets/$1"
        },
        {
            "src": "^/brand/(.*)$",
            "dest": "/brand/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}